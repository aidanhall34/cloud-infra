# Terraform variable values for the gateway deployment.
# Copy to terraform/terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit credentials.
#
# Alternatively, set sensitive values via environment variables:
#   export TF_VAR_linode_token="..."

# ── Linode credentials ─────────────────────────────────────────────────────────
# Generate a token with `make linode-deploy-token`

linode_token = "your-linode-api-token"

# ── Region / sizing ────────────────────────────────────────────────────────────

linode_region = "ap-southeast"
instance_type = "g6-nanode-1"

# ── Gateway image ──────────────────────────────────────────────────────────────
# Resolved automatically at plan/apply time via the linode_images data source.
# Terraform selects the latest private image whose label contains "alpine-gateway-".
# No variable needed — run `make packer-build-gateway` before `make tf-apply`.

# ── Access ─────────────────────────────────────────────────────────────────────

ssh_public_key = "ssh-ed25519 AAAA..."

# ── Firewall ───────────────────────────────────────────────────────────────────
# All inbound traffic is dropped except from this CIDR.
# Use /32 for a single host, /24 for a subnet.
# Find your current public IP: curl -s https://ifconfig.me

allowed_ip_range = "203.0.113.1/32"
