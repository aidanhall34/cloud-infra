# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — do not commit it.
#
# ── Secrets ──────────────────────────────────────────────────────────────────
# Secrets are NOT passed as Terraform variables. They are read directly from
# files in the secrets/ directory (gitignored) by secrets.tf:
#
#   secrets/wireguard_gateway_private.key  ← generated by wg genkey
#   secrets/wireguard_gateway_public.key   ← derived from private key (share with MikroTik)
#   secrets/wireguard_mikrotik_public.key  ← paste MikroTik's public key here
#   secrets/grafana_github_client_id       ← from make setup-oauth
#   secrets/grafana_github_client_secret   ← from make setup-oauth
#   secrets/grafana_secret_key             ← from make generate-grafana-key
#
# For CI/CD, write the secret files before running terraform:
#   echo "$WG_PRIVATE_KEY"       > secrets/wireguard_gateway_private.key
#   echo "$WG_PUBLIC_KEY"        > secrets/wireguard_gateway_public.key
#   echo "$MIKROTIK_PUBKEY"      > secrets/wireguard_mikrotik_public.key
#   echo "$GRAFANA_CLIENT_ID"    > secrets/grafana_github_client_id
#   echo "$GRAFANA_CLIENT_SEC"   > secrets/grafana_github_client_secret
#   echo "$GRAFANA_SECRET_KEY"   > secrets/grafana_secret_key

# ── Oracle Cloud credentials ──────────────────────────────────────────────────
tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "aa:bb:cc:dd:..."
private_key_path = "~/.oci/oci_api_key.pem"
compartment_ocid = "ocid1.tenancy.oc1..aaaa..."  # same as tenancy_ocid for root compartment

# ── Instance access ───────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# ── Optional overrides ────────────────────────────────────────────────────────

# Public domain for the static site. Leave empty to skip TLS provisioning.

# If ARM capacity is unavailable in AD 0, try index 1 or 2.
# availability_domain_index = 0
