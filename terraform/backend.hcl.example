# Copy to secrets/backend.hcl and fill in your values.
# This file is read by: terraform init -backend-config=../secrets/backend.hcl
# secrets/backend.hcl is gitignored — never commit it.
#
# ── OCI Object Storage setup (one-time) ─────────────────────────────────────
#
# 1. Create the bucket (free tier, 10 GB included):
#    OCI Console → Object Storage → Buckets → Create Bucket
#    Name: terraform-state  |  Region: ap-sydney-1  |  Visibility: Private
#
# 2. Find your tenancy namespace:
#    OCI Console → Object Storage → Buckets  (namespace shown in page header)
#    Or via CLI: oci os ns get
#
# 3. Create Customer Secret Keys (S3 HMAC credentials — different from API keys):
#    OCI Console → Profile → User Settings → Customer Secret Keys → Generate Secret Key
#    Copy the secret immediately — it won't be shown again.
#    The "Access Key" shown afterwards is the access_key below.

bucket                      = "terraform-state"
key                         = "homelab/terraform.tfstate"
region                      = "ap-sydney-1"
endpoint                    = "https://<namespace>.compat.objectstorage.ap-sydney-1.oraclecloud.com"
access_key                  = "<customer-secret-key-access-id>"
secret_key                  = "<customer-secret-key-secret-value>"
skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
force_path_style            = true
