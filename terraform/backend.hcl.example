# S3-compatible backend using Linode Object Storage.
# Copy to secrets/backend.hcl and fill in the values.
# secrets/backend.hcl is gitignored — never commit credentials.
#
# 1. Create a bucket:     https://cloud.linode.com/object-storage/buckets
# 2. Generate access keys: https://cloud.linode.com/object-storage/access-keys
#
# Cluster IDs by region:
#   ap-southeast  → ap-southeast-1
#   us-east       → us-east-1
#   eu-central    → eu-central-1

bucket                      = "your-bucket-name"
key                         = "terraform/gateway.tfstate"
region                      = "ap-southeast-1"
endpoint                    = "ap-southeast-1.linodeobjects.com"
access_key                  = "your-access-key"
secret_key                  = "your-secret-key"
skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
force_path_style            = true
